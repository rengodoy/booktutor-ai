# Keep the build context tiny — don't ship local venv/data into the image.
.venv/
.git/
.gitignore
__pycache__/
*.py[oc]
.pytest_cache/
.ruff_cache/

# Local data / secrets / generated artifacts
.env
indexes/
books/
*_faiss_index/
*.pdf

# OCR language data (the image installs tesseract lang packs from apt)
*.traineddata
