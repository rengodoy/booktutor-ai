# Copy to .env and adjust. Tunes the OCR pipeline.

# --- OCR --------------------------------------------------------------------
# Manual escalation when quality is poor (worst -> best on bad scans):
#   easyocr   -> local-friendly (GPU)           [run locally with uv]
#   tesseract -> needs tesseract + lang packs   [run in Docker]
#   vlm       -> DeepSeek-OCR via vLLM           [run in Docker, best quality]
#   none      -> trust the PDF text layer (no OCR)
OCR_ENGINE=easyocr
OCR_LANGUAGES=en                 # comma-separated, e.g. "pt,en"
OCR_FORCE_FULL_PAGE=false        # true = re-OCR whole page, ignoring a bad text layer
OCR_NUM_THREADS=8

# --- VLM-OCR (only when OCR_ENGINE=vlm) -------------------------------------
# DeepSeek-OCR served by vLLM, OpenAI-compatible vision endpoint.
VLM_OCR_API_BASE=http://localhost:8000/v1
VLM_OCR_API_KEY=not-needed
VLM_OCR_MODEL=unsloth/DeepSeek-OCR
VLM_OCR_PROMPT=Free OCR.
VLM_OCR_MAX_TOKENS=4096   # output/page; leave room for image input within max-model-len
VLM_OCR_DPI=144
