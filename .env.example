# Copy to .env and fill in. Any OpenAI-compatible endpoint works.

# --- Chat LLM ---------------------------------------------------------------
# OpenAI:        https://api.openai.com/v1   (set LLM_API_KEY to your sk-... key)
# LM Studio:     http://localhost:1234/v1
# Ollama:        http://localhost:11434/v1
# vLLM / other:  http://localhost:8000/v1
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=not-needed
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# --- Embeddings -------------------------------------------------------------
# Backend: "openai" (call an OpenAI-compatible endpoint) or
#          "local"  (run sentence-transformers in-process, no server needed).
EMBEDDING_BACKEND=openai

# When EMBEDDING_BACKEND=openai:
# Leave EMBEDDING_API_BASE / EMBEDDING_API_KEY empty to reuse the LLM ones.
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# When EMBEDDING_BACKEND=local (a sentence-transformers model id):
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking / retrieval ---------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# --- Storage ----------------------------------------------------------------
INDEX_DIR=indexes

# --- OCR --------------------------------------------------------------------
# Manual escalation when quality is poor (worst -> best on bad scans):
#   easyocr   -> local-friendly (GPU)           [run locally with uv]
#   tesseract -> needs tesseract + lang packs   [run in Docker]
#   vlm       -> DeepSeek-OCR via vLLM           [run in Docker, best quality]
#   none      -> trust the PDF text layer (no OCR)
OCR_ENGINE=easyocr
OCR_LANGUAGES=en                 # comma-separated, e.g. "pt,en"
OCR_FORCE_FULL_PAGE=false        # true = re-OCR whole page, ignoring a bad text layer
OCR_NUM_THREADS=8

# --- VLM-OCR (only when OCR_ENGINE=vlm) -------------------------------------
# DeepSeek-OCR served by vLLM, OpenAI-compatible vision endpoint.
VLM_OCR_API_BASE=http://localhost:8000/v1
VLM_OCR_API_KEY=not-needed
VLM_OCR_MODEL=unsloth/DeepSeek-OCR
VLM_OCR_PROMPT=Free OCR.
VLM_OCR_MAX_TOKENS=4096   # output/page; leave room for image input within max-model-len
VLM_OCR_DPI=144
