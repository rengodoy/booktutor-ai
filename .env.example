# Copy to .env and adjust. Tunes the OCR pipeline.
# glyph runs LOCALLY (thin orchestrator); the OCR engines are on-demand HTTP
# services it spins up via docker compose. URLs below target published ports on
# the host (127.0.0.1), not container hostnames.

# --- OCR --------------------------------------------------------------------
# Default "merge" is the one adaptive command: it starts on the simplest engine
# and a Vision-LLM judges each page, escalating the ladder only when confidence
# is low (it prints when it does). Pin a single engine to disable escalation:
#   merge     -> adaptive ladder + Vision-LLM reconciler   [DEFAULT]
#   none      -> trust the PDF text layer (no OCR)
#   easyocr   -> docling + EasyOCR (GPU-friendly)
#   tesseract -> docling + Tesseract (Docker: lang packs installed)
#   deepseek2 -> DeepSeek-OCR-2 in-process (CUDA GPU; run the deepseek2 service)
OCR_ENGINE=merge
OCR_LANGUAGES=en                 # comma-separated, e.g. "pt,en"
OCR_FORCE_FULL_PAGE=false        # true = re-OCR whole page, ignoring a bad text layer
OCR_NUM_THREADS=8

# --- Merge: the adaptive pipeline (OCR_ENGINE=merge) ------------------------
# Per page, escalate through tiers of source engines until the Vision-LLM
# reconciler's confidence reaches MERGE_MIN_CONFIDENCE. ';'-separated tiers,
# each a ','-list of engines (docling engines: easyocr, tesseract; plus the
# deepseek2 HTTP server). Simplest first -> strongest last.
MERGE_TIERS=easyocr;tesseract;easyocr,tesseract;easyocr,tesseract,deepseek2
# The Vision-LLM reconciler/judge. Runs on the HOST GPU0 (an OpenAI-compatible
# vision endpoint, e.g. llama.cpp). glyph is local, so reach it on 127.0.0.1.
MERGE_API_BASE=http://127.0.0.1:8080/v1
MERGE_API_KEY=not-needed                   # any non-empty string
MERGE_MODEL=gemma-qat                       # small vision model; leaves GPU room for deepseek2
MERGE_MAX_TOKENS=8192
MERGE_DPI=144
MERGE_MIN_CONFIDENCE=0.85                  # escalate while confidence < this
# true (default) = escalate the ladder while confidence < MERGE_MIN_CONFIDENCE.
# false = run only the first MERGE_TIERS tier and accept its result (one-off:
# pass --no-escalate). Only affects `merge` with more than one tier.
MERGE_ESCALATE=true
# true = reflow into continuous prose: strip page numbers/headers, join words
# split across lines, and stitch a sentence/word split across a page break;
# false = keep the page's literal line breaks.
MERGE_PROSE=true
# Extract figures embedded in the PDF as PNGs next to the .md (in a sibling
# "<name>.assets/" dir) and point the markdown image links at them so they
# render. false = leave figures out. MERGE_MIN_FIGURE_PT is the minimum
# displayed size (PDF points, 1pt = 1/72in) for an embedded image to count as a
# figure — filters icons / bullets / header strips.
MERGE_IMAGES=true
MERGE_MIN_FIGURE_PT=72
# Stitch a table split across a page break into one table (drops the repeated
# header on the continuation) and feed the previous page's tail to the
# reconciler so it continues a table/list/sentence that spans pages. false =
# keep each page's table fragment separate.
MERGE_TABLES=true
# The easyocr/tesseract source tiers -> the docling service (compose). The
# orchestrator spins it up on demand and stops it at the end.
MERGE_DOCLING_URL=http://127.0.0.1:8002
# The deepseek2 source tier -> the deepseek2 service (compose). If it's down,
# that candidate is skipped and the run continues with the other engines.
MERGE_DEEPSEEK2_URL=http://127.0.0.1:8001

# --- On-demand service lifecycle (docker compose, run from the host) --------
# NB: COMPOSE_FILE / COMPOSE_PROJECT_NAME are read by `docker compose` itself from
# this .env, so don't set them here (a stray value breaks `up`). To point glyph at
# a different compose file, export GLYPH_COMPOSE_FILE instead.
SERVICE_AUTOSTART=true                 # spin engine services up on demand
SERVICE_STOP_ON_EXIT=true             # stop the ones we started at the end
DOCLING_HEALTH_TIMEOUT=180            # easyocr first-run weight download (s)
DEEPSEEK2_HEALTH_TIMEOUT=600          # ds2 model load — minutes-long cold start (s)
HEALTH_POLL_INTERVAL=2.0

# --- DeepSeek-OCR-2 (deepseek2 service / OCR_ENGINE=deepseek2) ---------------
# Runs in-process via transformers (trust_remote_code). Needs a CUDA GPU; the
# weights download once and are cached (HF_HOME volume).
DS2_MODEL=deepseek-ai/DeepSeek-OCR-2   # or unsloth/DeepSeek-OCR-2 (set DS2_IMAGE_SIZE=640)
DS2_PROMPT=<image>\n<|grounding|>Convert the document to markdown.
DS2_BASE_SIZE=1024
DS2_IMAGE_SIZE=768
DS2_CROP_MODE=true
DS2_ATTN_IMPL=eager   # "eager" runs anywhere; "flash_attention_2" needs flash-attn
DS2_DPI=144
# Standalone OCR HTTP server (glyph-deepseek2-server) — the merge deepseek2 tier.
DS2_SERVER_HOST=0.0.0.0
DS2_SERVER_PORT=8001

# --- docling HTTP service (glyph-docling-server) — easyocr/tesseract tiers ---
DOCLING_SERVER_HOST=0.0.0.0
DOCLING_SERVER_PORT=8002
