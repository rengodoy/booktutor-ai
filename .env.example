# Copy to .env and adjust. Tunes the OCR pipeline.

# --- OCR --------------------------------------------------------------------
# Manual escalation when quality is poor (worst -> best on bad scans):
#   easyocr   -> local-friendly (GPU)           [run locally with uv]
#   tesseract -> needs tesseract + lang packs   [run in Docker]
#   vlm       -> DeepSeek-OCR via vLLM           [run in Docker, best quality]
#   deepseek2 -> DeepSeek-OCR-2 in-process       [needs CUDA GPU; no server]
#   merge     -> adaptive multi-engine + Vision-LLM reconciler  [needs endpoint]
#   none      -> trust the PDF text layer (no OCR)
OCR_ENGINE=easyocr
OCR_LANGUAGES=en                 # comma-separated, e.g. "pt,en"
OCR_FORCE_FULL_PAGE=false        # true = re-OCR whole page, ignoring a bad text layer
OCR_NUM_THREADS=8

# --- VLM-OCR (only when OCR_ENGINE=vlm) -------------------------------------
# DeepSeek-OCR served by vLLM, OpenAI-compatible vision endpoint.
VLM_OCR_API_BASE=http://localhost:8000/v1
VLM_OCR_API_KEY=not-needed
VLM_OCR_MODEL=unsloth/DeepSeek-OCR
VLM_OCR_PROMPT=Free OCR.
VLM_OCR_MAX_TOKENS=4096   # output/page; leave room for image input within max-model-len
VLM_OCR_DPI=144

# --- DeepSeek-OCR-2 (only when OCR_ENGINE=deepseek2) ------------------------
# Runs in-process via transformers (trust_remote_code). Needs a CUDA GPU; the
# weights download once and are cached by Hugging Face.
DS2_MODEL=deepseek-ai/DeepSeek-OCR-2   # or unsloth/DeepSeek-OCR-2 (set DS2_IMAGE_SIZE=640)
DS2_PROMPT=<image>\n<|grounding|>Convert the document to markdown.
DS2_BASE_SIZE=1024
DS2_IMAGE_SIZE=768
DS2_CROP_MODE=true
DS2_ATTN_IMPL=eager   # "eager" runs anywhere; "flash_attention_2" needs flash-attn
DS2_DPI=144
# Standalone OCR HTTP server (booktutor-deepseek2-server) — lets `merge` use it.
DS2_SERVER_HOST=0.0.0.0
DS2_SERVER_PORT=8001

# --- Merge (only when OCR_ENGINE=merge) -------------------------------------
# Per page, escalate through tiers of source engines until the Vision-LLM
# reconciler's confidence reaches MERGE_MIN_CONFIDENCE. ';'-separated tiers,
# each a ','-list of engines (docling engines: easyocr, tesseract).
MERGE_TIERS=easyocr;tesseract;easyocr,tesseract
MERGE_API_BASE=http://127.0.0.1:8080/v1   # your OpenAI-compatible vision endpoint
MERGE_API_KEY=not-needed                   # any non-empty string
MERGE_MODEL=qwen-27b                       # the reconciler/judge (vision model)
MERGE_MAX_TOKENS=8192
MERGE_DPI=144
MERGE_MIN_CONFIDENCE=0.85                  # escalate while confidence < this
